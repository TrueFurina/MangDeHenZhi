# ============================================================
# 芒得很职 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---- 数据库 (MySQL) ----
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=mangdehenzhi
MYSQL_USER=mangdehenzhi
# 必须设置为强随机口令（openssl rand -base64 24），勿在仓库提交真实口令
MYSQL_PASSWORD=
# 可选：root 口令（生产必填，留空则启动失败）
MYSQL_ROOT_PASSWORD=

# ---- JWT 密钥 ----
# 必须设置为强随机密钥（至少32字符），命令：openssl rand -base64 48
# 留空则生产环境（prod profile）后端启动失败（fail-fast），本地开发可留空使用占位密钥。
JWT_SECRET=

# ---- DeepSeek 大模型 API ----
# 从 https://platform.deepseek.com 获取 API Key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ---- CORS 允许的域名 ----
# 多个域名用逗号分隔，如 https://example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=*

# ---- Spring 配置 ----
SPRING_PROFILES_ACTIVE=dev