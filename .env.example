# ============================================================
# 芒德矩阵 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---- 数据库 (MySQL) ----
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=mangdehenzhi
MYSQL_USER=mangdehenzhi
MYSQL_PASSWORD=mangdehenzhi123

# ---- JWT 密钥 ----
# 生产环境请务必修改为随机长字符串（至少32字符）
JWT_SECRET=mangdehenzhi-jwt-secret-key-2026-very-long-secret-for-security

# ---- DeepSeek 大模型 API ----
# 从 https://platform.deepseek.com 获取 API Key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ---- CORS 允许的域名 ----
# 多个域名用逗号分隔，如 https://example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=*

# ---- Spring 配置 ----
SPRING_PROFILES_ACTIVE=dev